{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "development" }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "preview" }
    },
    "production": {
      "autoIncrement": true,
      "env": { "EXPO_PUBLIC_ENVIRONMENT": "production" }
    }
  },
  "submit": {
    "production": {}
  }
}
