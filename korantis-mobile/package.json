{
  "name": "korantis-mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "dependencies": {
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo-google-fonts/playfair-display": "^0.4.2",
    "@expo/ui": "~56.0.18",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/query-async-storage-persister": "^5.101.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-query-persist-client": "^5.101.0",
    "expo": "~56.0.12",
    "expo-auth-session": "~56.0.14",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-image": "~56.0.11",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.18",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "mapbox-gl": "^2.15.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/mapbox-gl": "^2.7.21",
    "@types/react": "~19.2.2",
    "concurrently": "^10.0.3",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^56.0.4",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  },
  "scripts": {
    "start": "concurrently -k -n api,expo \"node scripts/dev-api-proxy.mjs\" \"expo start\"",
    "android": "expo run:android",
    "android:dev": "expo start --android",
    "build:android:dev": "npx eas-cli@latest build --platform android --profile development",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:android:production": "npx eas-cli@latest build --platform android --profile production",
    "ios": "expo run:ios",
    "build:ios:production": "npx eas-cli@latest build --platform ios --profile production",
    "web": "concurrently -k -n api,expo \"node scripts/dev-api-proxy.mjs\" \"expo start --web\"",
    "lint": "expo lint --no-cache",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "patch-package"
  },
  "private": true
}
